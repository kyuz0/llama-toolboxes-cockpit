      "registry": "docker.io/kyuz0/amd-strix-halo-toolboxes",
      "groups": [
        {
          "name": "Official Toolboxes",
          "toolboxes": [
            {
              "name": "llama-rocm-7.2.3",
              "tag": "rocm-7.2.3",
              "description": "Stable ROCm 7.2.3 backend (recommended)",
              "engine_args": [
                "--device",
                "/dev/dri",
                "--device",
                "/dev/kfd",
                "--group-add",
                "video",
